rules_version = '2';

// Hanya user yang sudah login (dibuat manual lewat Firebase Console > Authentication)
// yang boleh baca/tulis data. Tidak ada pendaftaran akun publik.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
